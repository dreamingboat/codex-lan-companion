{
  "name": "codex-lan-companion",
  "version": "0.1.0",
  "private": false,
  "description": "LAN-only browser companion for viewing and lightly controlling Codex Desktop.",
  "type": "module",
  "bin": {
    "codex-lan-companion": "./server.js"
  },
  "files": [
    "server.js",
    "public",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "node --check server.js && node --check public/app.js",
    "start": "node server.js",
    "start:readonly": "node server.js --readonly"
  },
  "keywords": [
    "codex",
    "codex-desktop",
    "lan",
    "remote",
    "companion",
    "mobile",
    "browser",
    "local-first"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "qrcode-terminal": "^0.12.0"
  }
}
